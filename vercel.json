{
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.4"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.{css,js,jpg,jpeg,png,gif,svg,ico,woff,woff2}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}